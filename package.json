{
  "devDependencies": {
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.html": [
      "prettier --write"
    ],
    "frontend/**/*.css": [
      "prettier --write"
    ],
    "backend/**/*.java": [
      "prettier --write"
    ]
  }
}
